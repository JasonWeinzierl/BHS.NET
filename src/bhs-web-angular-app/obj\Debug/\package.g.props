    <PackageJsonDependenciesStandardSchemaSpec Condition="$(PackageJsonDependenciesStandardSchemaSpec) == ''">^1.1.0</PackageJsonDependenciesStandardSchemaSpec>
    <PackageJsonDependenciesBhsGeneratedModels Condition="$(PackageJsonDependenciesBhsGeneratedModels) == ''">workspace:^</PackageJsonDependenciesBhsGeneratedModels>
