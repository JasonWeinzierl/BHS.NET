    <PackageJsonDependenciesMicrosoftApplicationinsightsAngularpluginJs Condition="$(PackageJsonDependenciesMicrosoftApplicationinsightsAngularpluginJs) == ''">^15.3.8</PackageJsonDependenciesMicrosoftApplicationinsightsAngularpluginJs>
