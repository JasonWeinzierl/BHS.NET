<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <PackageJsonName Condition="$(PackageJsonName) == ''">bhs-web-angular-app</PackageJsonName>
    <PackageJsonVersion Condition="$(PackageJsonVersion) == ''">0.0.0</PackageJsonVersion>
    <PackageJsonPrivate Condition="$(PackageJsonPrivate) == ''">true</PackageJsonPrivate>
    <PackageJsonDescription Condition="$(PackageJsonDescription) == ''">Client-side Angular application for BHS.NET</PackageJsonDescription>
    <PackageJsonType Condition="$(PackageJsonType) == ''">commonjs</PackageJsonType>
    <PackageJsonScriptsBuild Condition="$(PackageJsonScriptsBuild) == ''">node ../bhs-generated-models/check-codegen.mjs &amp;&amp; ng build</PackageJsonScriptsBuild>
    <PackageJsonScriptsBuildRelease Condition="$(PackageJsonScriptsBuildRelease) == ''">ng build --configuration release</PackageJsonScriptsBuildRelease>
    <PackageJsonScriptsClean Condition="$(PackageJsonScriptsClean) == ''">ng cache clean</PackageJsonScriptsClean>
    <PackageJsonScriptsLint Condition="$(PackageJsonScriptsLint) == ''">ng lint</PackageJsonScriptsLint>
    <PackageJsonScriptsStart Condition="$(PackageJsonScriptsStart) == ''">ng serve</PackageJsonScriptsStart>
    <PackageJsonScriptsStartProxy Condition="$(PackageJsonScriptsStartProxy) == ''">node scripts/aspnetcore-https.mjs &amp;&amp; run-script-os</PackageJsonScriptsStartProxy>
    <PackageJsonScriptsStartProxyDefault Condition="$(PackageJsonScriptsStartProxyDefault) == ''">ng serve --configuration proxy --ssl-cert "$HOME/.aspnet/https/$npm_package_name.pem" --ssl-key "$HOME/.aspnet/https/$npm_package_name.key"</PackageJsonScriptsStartProxyDefault>
    <PackageJsonScriptsStartProxyWindows Condition="$(PackageJsonScriptsStartProxyWindows) == ''">ng serve --configuration proxy --ssl-cert "%APPDATA%\ASP.NET\https\%npm_package_name%.pem" --ssl-key "%APPDATA%\ASP.NET\https\%npm_package_name%.key"</PackageJsonScriptsStartProxyWindows>
    <PackageJsonScriptsTest Condition="$(PackageJsonScriptsTest) == ''">ng test</PackageJsonScriptsTest>
    <PackageJsonScriptsTestCi Condition="$(PackageJsonScriptsTestCi) == ''">ng test --configuration ci</PackageJsonScriptsTestCi>
    <PackageJsonScriptsTransformRelease Condition="$(PackageJsonScriptsTransformRelease) == ''">node scripts/transform-release.mjs</PackageJsonScriptsTransformRelease>
    <PackageJsonDependenciesAngularAnimations Condition="$(PackageJsonDependenciesAngularAnimations) == ''">21.2.13</PackageJsonDependenciesAngularAnimations>
    <PackageJsonDependenciesAngularCommon Condition="$(PackageJsonDependenciesAngularCommon) == ''">21.2.13</PackageJsonDependenciesAngularCommon>
    <PackageJsonDependenciesAngularCompiler Condition="$(PackageJsonDependenciesAngularCompiler) == ''">21.2.13</PackageJsonDependenciesAngularCompiler>
    <PackageJsonDependenciesAngularCore Condition="$(PackageJsonDependenciesAngularCore) == ''">21.2.13</PackageJsonDependenciesAngularCore>
    <PackageJsonDependenciesAngularForms Condition="$(PackageJsonDependenciesAngularForms) == ''">21.2.13</PackageJsonDependenciesAngularForms>
