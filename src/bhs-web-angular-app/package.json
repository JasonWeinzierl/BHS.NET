{
  "name": "bhs-web-angular-app",
  "version": "0.0.0",
  "private": true,
  "description": "Client-side Angular application for BHS.NET",
  "type": "commonjs",
  "scripts": {
    "build": "node ../bhs-generated-models/check-codegen.mjs && ng build",
    "build-release": "ng build --configuration release",
    "clean": "ng cache clean",
    "lint": "ng lint",
    "start": "ng serve",
    "start-proxy": "node scripts/aspnetcore-https.mjs && run-script-os",
    "start-proxy:default": "ng serve --configuration proxy --ssl-cert \"$HOME/.aspnet/https/$npm_package_name.pem\" --ssl-key \"$HOME/.aspnet/https/$npm_package_name.key\"",
    "start-proxy:windows": "ng serve --configuration proxy --ssl-cert \"%APPDATA%\\ASP.NET\\https\\%npm_package_name%.pem\" --ssl-key \"%APPDATA%\\ASP.NET\\https\\%npm_package_name%.key\"",
    "test": "ng test",
    "test-ci": "ng test --configuration ci",
    "transform-release": "node scripts/transform-release.mjs"
  },
  "dependencies": {
    "@angular/animations": "22.0.0",
    "@angular/common": "22.0.0",
    "@angular/compiler": "22.0.1",
    "@angular/core": "22.0.0",
    "@angular/forms": "22.0.0",
    "@angular/platform-browser": "22.0.0",
    "@angular/router": "22.0.0",
    "@auth0/auth0-angular": "^2.9.0",
    "@microsoft/applicationinsights-analytics-js": "3.4.1",
    "@microsoft/applicationinsights-angularplugin-js": "^15.4.0",
    "@microsoft/applicationinsights-web": "^3.4.1",
    "@standard-schema/spec": "^1.1.0",
    "bhs-generated-models": "workspace:^",
    "bootstrap-icons": "1.13.1",
    "jwt-decode": "^4.0.0",
    "marked": "^17.0.4",
    "ngx-toastr": "^20.0.5",
    "pretty-ms": "^9.3.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "22.0.0",
    "@angular/compiler-cli": "22.0.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/eslint-plugin": "^1.6.19",
    "angular-eslint": "22.0.0",
    "daisyui": "^5.5.19",
    "eslint": "^10.4.1",
    "eslint-config-flat-gitignore": "^2.3.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-better-tailwindcss": "~4.3.2",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^63.0.1",
    "eslint-plugin-package-json": "^1.3.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-rxjs-angular-x": "^1.0.1",
    "eslint-plugin-rxjs-x": "^1.0.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "jsdom": "^28.1.0",
    "jsonc-eslint-parser": "^3.1.0",
    "merge-partially": "^2.0.2",
    "postcss": "^8.5.15",
    "run-script-os": "^1.1.6",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
